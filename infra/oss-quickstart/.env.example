# OSS quickstart — environment overrides for `docker compose up`.
#
# `cp .env.example .env && docker compose up` works as-is with the
# defaults below. The bootstrap-admin email below is a sentinel for
# a local-laptop evaluation; rotate it to a real address before
# exposing the stack to anyone else.

# REQUIRED — the bootstrap-admin Employee. This email gets the
# `platform-admin` role at boot and is the SPA's session identity
# until real auth lands.
BOSS_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Optional — bootstrap-admin's initial password for the file-backed
# credential store. Defaults to 'change-me' if unset. Rotate with
# `docker compose exec boss-services boss-auth set $EMAIL` after
# first login — that's a strict requirement before exposing the
# stack to anything other than your laptop.
# BOSS_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Optional — default `info`. Set `debug` for service-level traces.
BOSS_LOG_LEVEL=info
