{
  "name": "boss-web",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "description": "Svelte 5 frontend for BOSS. Shipped 2026-04-23 via the 4-phase Svelte migration (see ADRs 0078-0084 + docs/design/svelte-migration.md).",
  "scripts": {
    "dev": "bun --hot src/dev-server.ts",
    "build": "bun run src/build.ts",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "bun test src/",
    "test:mocked": "playwright test -c playwright.mocked.config.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/svelte": "^1.6.0",
    "puppeteer": "^25.1.0",
    "svelte": "^5.55.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "bun-plugin-svelte": "^0.0.6",
    "bun-types": "^1.3.14",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3"
  }
}
